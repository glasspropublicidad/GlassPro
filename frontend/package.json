{
  "name": "frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "images:avif": "npm exec --yes --package=sharp -- node ./scripts/convert-missing-avif.mjs",
    "images:og": "npm exec --yes --package=sharp -- node ./scripts/generate-og-image.mjs",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@portabletext/react": "^6.0.3",
    "@react-router/node": "7.12.0",
    "@react-router/serve": "7.12.0",
    "@sanity/client": "^7.16.0",
    "@sanity/image-url": "^2.0.3",
    "framer-motion": "^12.34.3",
    "isbot": "^5.1.31",
    "lenis": "^1.3.17",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.12.0"
  },
  "devDependencies": {
    "@react-router/dev": "7.12.0",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^22",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  }
