# ─────────────────────────────────────────────────
# GlassPro — Environment Variables
# ─────────────────────────────────────────────────
# Copy this file to .env for local development.
# On Vercel, set these in: Dashboard → Settings → Environment Variables
#
# IMPORTANT: .env is gitignored — never commit real keys.
# ─────────────────────────────────────────────────

# Sanity CMS — https://manage.sanity.io
SANITY_PROJECT_ID=0bnpr7m2
SANITY_DATASET=production

# Resend (email service) — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Email address that receives contact form submissions
CONTACT_EMAIL=contacto@glasspro.mx

# "From" domain for outgoing emails (must be verified in Resend)
RESEND_FROM_DOMAIN=noreply@glasspro.mx
