# GlassPro - Environment Variables
# Copy this file to .env for local development.
# On Vercel, set these in Dashboard -> Settings -> Environment Variables.
#
# IMPORTANT: .env is gitignored. Never commit real keys.

# Sanity CMS - https://manage.sanity.io
SANITY_PROJECT_ID=0bnpr7m2
SANITY_DATASET=production

# Public site URL used for canonical URLs, OG tags and sitemap generation
VITE_SITE_URL=https://glass-pro.mx

# Resend - private server-side API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Internal email that receives contact form submissions
CONTACT_FORM_TO_EMAIL=contacto@glass-pro.mx

# Visible sender for outgoing emails. Must use a verified Resend domain.
CONTACT_FORM_FROM_EMAIL=GlassPro Contacto <noreply@glass-pro.mx>
